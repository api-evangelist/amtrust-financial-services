{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amtrust-financial-services/refs/heads/main/json-structure/amtrust-financial-services-appetite-response-structure.json",
  "name": "AppetiteResponse",
  "description": "Coverage appetite check result",
  "type": "object",
  "properties": {
    "eligible": {
      "type": "boolean",
      "description": "Whether AmTrust has appetite for this risk",
      "example": true
    },
    "products": {
      "type": "array",
      "description": "Available products for this risk",
      "items": {
        "type": "string"
      },
      "example": [
        "workers_compensation"
      ]
    },
    "bind_online": {
      "type": "boolean",
      "description": "Whether the policy can be bound online",
      "example": true
    },
    "reason": {
      "type": "string",
      "description": "Reason if not eligible",
      "example": "Eligible for online quoting and binding"
    }
  }
}